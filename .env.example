# StudyClub++ 로컬 개발 env 예시 — 복사해서 .env 로 쓰세요:  cp .env.example .env
# ⚠️ PUBLIC 레포 — 실제 값(구글 시크릿·운영 비밀번호)은 .env(gitignore)에만. 여기엔 로컬 더미만.

# --- MySQL (로컬 docker 전용 더미) ---
MYSQL_ROOT_PASSWORD=studyclub_root_local
MYSQL_DATABASE=studyclub
MYSQL_USER=studyclub
MYSQL_PASSWORD=studyclub_local
MYSQL_PORT=3310

# --- API ---
# 백오피스 접근 allowlist (콤마 구분, 대소문자 무시)
BACK_OFFICE_ALLOWED_EMAILS=karjyk@gmail.com
# JWT 서명키 (로컬 더미 — 운영은 fleet/secret/ 에서 주입)
JWT_SECRET=local-dev-jwt-secret-change-me

# --- Google OAuth (GCP 콘솔에서 클라이언트 생성 후 채움; 그 전엔 비워도 부팅됨) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4700/api/auth/callback

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
